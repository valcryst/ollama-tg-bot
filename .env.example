BOT_TOKEN=your_telegram_bot_token_here

# Logging: ERROR (default) | DEBUG
# LOGGING_LEVEL=ERROR

# Optional: Tavily web search (https://tavily.com)
# TAVILY_API_KEY=tvly-...

# Optional: API key for authenticated OpenAI-compatible endpoints. Local servers can leave it unset.
# OPENAI_API_KEY=sk-...

# Required for npm run test:llm -w server
# LLM_BASE_URL=https://your-localai-host/v1
# LLM_MODEL=your-model-name

# Required - GPU VRAM available for LLM (gigabytes). Used to derive context window.
VRAM_AVAILABLE=24

# IRC training mode — local testing with pymcp-ircd (no Telegram token needed)
# IRC_TRAINING_MODE=true
# IRC_SERVER=127.0.0.1:6667
# IRC_CHANNELS=#bot-training
# IRC_NICK=ollama-bot
